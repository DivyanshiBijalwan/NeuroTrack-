@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">COGNITIVE PERFORMANCE SYSTEM</div>
        <h1>Analyze Your<br /><span class="gradient-text">Brain Performance</span></h1>
        <p class="hero-sub">Three scientifically-designed tests measure your reaction time,
            memory capacity, and focus accuracy — then score you in real time.</p>
        <div class="hero-actions">
            <a href="/Test/Reaction" class="btn-primary">▶ Start Tests</a>
            <a href="/Test/History" class="btn-ghost">View History</a>
        </div>
    </div>
    <div class="hero-visual">
        <div class="brain-ring ring1"></div>
        <div class="brain-ring ring2"></div>
        <div class="brain-ring ring3"></div>
        <div class="brain-core">🧠</div>
    </div>
</section>

<section class="features">
    <div class="feature-card">
        <div class="feat-icon">⚡</div>
        <h3>Reaction Time</h3>
        <p>Measure how fast your brain responds to visual stimuli in milliseconds.</p>
    </div>
    <div class="feature-card">
        <div class="feat-icon">🃏</div>
        <h3>Memory Test</h3>
        <p>Flip cards and match pairs to assess your short-term memory accuracy.</p>
    </div>
    <div class="feature-card">
        <div class="feat-icon">🎯</div>
        <h3>Focus Test</h3>
        <p>Click only the correct targets appearing on screen — ignore the distractors.</p>
    </div>
</section>
